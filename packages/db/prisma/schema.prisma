generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobType {
  ADD_PLAYWRIGHT_TEST
}

enum JobStatus {
  DRAFT
  QUEUED
  CLAIMED
  RUNNING
  VALIDATING
  REVIEW
  COMPLETED
  FAILED
  BLOCKED
  RETRY
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WorkerStatus {
  IDLE
  BUSY
  OFFLINE
  ERROR
}

enum RepositoryProvider {
  GITHUB
}

enum RunStatus {
  STARTED
  CODEX_RUNNING
  VALIDATING
  PUSHING
  PR_CREATED
  SUCCEEDED
  FAILED
}

enum JobEventType {
  JOB_CREATED
  JOB_CLAIMED
  JOB_RUNNING
  RUN_STARTED
  WORKER_SIMULATED_WORK_COMPLETE
  JOB_RESET
}

model QueueControl {
  id        String    @id
  paused    Boolean   @default(false)
  pausedAt  DateTime? @map("paused_at")
  resumedAt DateTime? @map("resumed_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("queue_controls")
}

model Repository {
  id            String             @id @default(uuid()) @db.Uuid
  provider      RepositoryProvider @default(GITHUB)
  owner         String
  name          String
  defaultBranch String             @default("main") @map("default_branch")
  cloneUrl      String             @map("clone_url")
  webUrl        String             @map("web_url")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  jobs          Job[]

  @@unique([provider, owner, name])
  @@map("repositories")
}

model Job {
  id          String      @id @default(uuid()) @db.Uuid
  jobType     JobType     @map("job_type")
  status      JobStatus   @default(QUEUED)
  priority    JobPriority @default(NORMAL)
  payload     Json
  repositoryId String?     @map("repository_id") @db.Uuid
  claimedBy   String?     @map("claimed_by")
  claimedAt   DateTime?   @map("claimed_at")
  completedAt DateTime?   @map("completed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  events      JobEvent[]
  repository  Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  runs        Run[]

  @@index([status, priority, createdAt])
  @@index([repositoryId])
  @@map("jobs")
}

model Run {
  id          String    @id @default(uuid()) @db.Uuid
  jobId       String    @map("job_id") @db.Uuid
  status      RunStatus @default(STARTED)
  workerId    String?   @map("worker_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([status])
  @@map("runs")
}

model JobEvent {
  id        String       @id @default(uuid()) @db.Uuid
  jobId     String       @map("job_id") @db.Uuid
  eventType JobEventType @map("event_type")
  message   String
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("job_events")
}

model Worker {
  id            String       @id @default(uuid()) @db.Uuid
  hostname      String
  status        WorkerStatus @default(IDLE)
  currentJob    String?      @map("current_job")
  lastHeartbeat DateTime     @default(now()) @map("last_heartbeat")
  version       String

  @@index([status])
  @@map("workers")
}
