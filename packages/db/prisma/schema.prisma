generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobType {
  ADD_PLAYWRIGHT_TEST
}

enum JobStatus {
  DRAFT
  NEEDS_REVIEW
  QUEUED
  CLAIMED
  RUNNING
  VALIDATING
  REVIEW
  PR_APPROVED
  PR_CREATED
  COMPLETED
  FAILED
  BLOCKED
  RETRY
  CANCELED
  READY_FOR_CODEX
  CODEX_APPROVED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WorkerStatus {
  IDLE
  BUSY
  OFFLINE
  ERROR
}

enum RepositoryProvider {
  GITHUB
}

enum TrackerProvider {
  JIRA
}

enum RunStatus {
  STARTED
  CODEX_RUNNING
  VALIDATING
  PUSHING
  PR_CREATED
  SUCCEEDED
  FAILED
  READY_FOR_CODEX
}

enum JobEventType {
  JOB_CREATED
  JOB_APPROVED
  JOB_UPDATED
  JOB_CLAIMED
  JOB_RUNNING
  RUN_STARTED
  WORKER_SIMULATED_WORK_COMPLETE
  JOB_RESET
  JOB_CANCELED
  REPOSITORY_CHECKOUT_VALIDATION_STARTED
  REPOSITORY_CHECKOUT_VALIDATED
  WORK_BRANCH_PREPARATION_STARTED
  TARGET_BRANCH_CHECKED_OUT
  WORK_BRANCH_CREATED
  CODEX_APPROVAL_REQUIRED
  CODEX_APPROVAL_GRANTED
  CODEX_INVOCATION_READY
  CODEX_INVOCATION_SKIPPED
  CODEX_INVOCATION_STARTED
  CODEX_INVOCATION_COMPLETED
  CODEX_INVOCATION_FAILED
  VALIDATION_STARTED
  VALIDATION_COMPLETED
  VALIDATION_FAILED
  PR_CREATION_STARTED
  WORK_BRANCH_COMMITTED
  WORK_BRANCH_PUSHED
  PR_CREATED
  PR_CHECKS_PENDING
  PR_CHECKS_PASSED
  PR_CHECKS_FAILED
  PR_MERGED
  PR_CLOSED
  LOCAL_CHECKOUT_CLEANUP_COMPLETED
  LOCAL_CHECKOUT_CLEANUP_FAILED
  PR_CREATION_FAILED
  PR_CREATION_APPROVED
  JOB_BLOCKED
  JIRA_TICKET_CREATED
  JIRA_TICKET_CREATION_FAILED
  JIRA_TICKET_CREATION_SKIPPED
}

model QueueControl {
  id        String    @id
  paused    Boolean   @default(false)
  pausedAt  DateTime? @map("paused_at")
  resumedAt DateTime? @map("resumed_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("queue_controls")
}

model Repository {
  id                   String              @id @default(uuid()) @db.Uuid
  provider             RepositoryProvider  @default(GITHUB)
  owner                String
  name                 String
  defaultBranch        String              @default("main") @map("default_branch")
  cloneUrl             String              @map("clone_url")
  webUrl               String              @map("web_url")
  localPath            String?             @map("local_path")
  validationCommand    String?             @map("validation_command")
  trackerIntegrationId String?             @map("tracker_integration_id") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  jobs                 Job[]
  trackerIntegration   TrackerIntegration? @relation(fields: [trackerIntegrationId], references: [id], onDelete: SetNull)

  @@unique([provider, owner, name])
  @@index([trackerIntegrationId])
  @@map("repositories")
}

model TrackerIntegration {
  id           String          @id @default(uuid()) @db.Uuid
  provider     TrackerProvider @default(JIRA)
  name         String
  baseUrl      String          @map("base_url")
  email        String
  apiToken     String          @map("api_token")
  projectKey   String          @map("project_key")
  issueType    String          @default("Task") @map("issue_type")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  repositories Repository[]

  @@unique([provider, name])
  @@map("tracker_integrations")
}

model Job {
  id           String      @id @default(uuid()) @db.Uuid
  jobType      JobType     @map("job_type")
  status       JobStatus   @default(QUEUED)
  priority     JobPriority @default(NORMAL)
  payload      Json
  repositoryId String?     @map("repository_id") @db.Uuid
  claimedBy    String?     @map("claimed_by")
  claimedAt    DateTime?   @map("claimed_at")
  completedAt  DateTime?   @map("completed_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  events       JobEvent[]
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  runs         Run[]

  @@index([status, priority, createdAt])
  @@index([repositoryId])
  @@map("jobs")
}

model Run {
  id          String    @id @default(uuid()) @db.Uuid
  jobId       String    @map("job_id") @db.Uuid
  status      RunStatus @default(STARTED)
  workerId    String?   @map("worker_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([status])
  @@map("runs")
}

model JobEvent {
  id        String       @id @default(uuid()) @db.Uuid
  jobId     String       @map("job_id") @db.Uuid
  eventType JobEventType @map("event_type")
  message   String
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("job_events")
}

model Worker {
  id            String       @id @default(uuid()) @db.Uuid
  hostname      String
  status        WorkerStatus @default(IDLE)
  currentJob    String?      @map("current_job")
  lastHeartbeat DateTime     @default(now()) @map("last_heartbeat")
  version       String

  @@index([status])
  @@map("workers")
}
