{
  "manifest_version": 3,
  "name": "FlawFerret",
  "version": "0.0.25",
  "description": "Capture exploratory QA context and create Jira issues faster.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*"
  ],
  "background": {
    "service_worker": "sw/qa_issue_background_service.js",
    "type": "module"
  },
  "options_page": "options/options.html"
}
